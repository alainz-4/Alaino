{
  "name": "@freelance/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate:all": "pnpm prisma:generate && pnpm prisma:generate:postgres",
    "prisma:generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "prisma:migrate:postgres": "prisma migrate dev --schema prisma/postgres/schema.prisma",
    "prisma:deploy:postgres": "prisma migrate deploy --schema prisma/postgres/schema.prisma"
  },
  "dependencies": {
    "@freelance/shared": "workspace:*",
    "@prisma/client": "^5.19.1",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^8.0.0",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.4",
    "prisma": "^5.19.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
